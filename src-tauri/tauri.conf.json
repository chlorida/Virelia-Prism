{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Virelia Prism",
  "version": "0.1.0",
  "identifier": "com.virelia.prism",
  "build": {
    "beforeDevCommand": "vite --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Virelia Prism",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 520,
        "decorations": false,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$AUDIO/**",
          "$VIDEO/**",
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/bin/windows/*": "bin/windows/",
      "resources/models/*": "models/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
